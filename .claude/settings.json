{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash(npm run build)",
      "Bash(npm run dev)",
      "Bash(npm run dev:*)",
      "Bash(npm run preview)",
      "Bash(npm run test)",
      "Bash(npm run test:*)",
      "Bash(npm install)",
      "Bash(npm install *)",
      "Bash(git status)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push)",
      "Bash(git push *)"
    ]
  }
}
